# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/techsage

# News API keys (optional — system works with RSS feeds alone)
NEWSAPI_KEY=
GNEWS_API_KEY=

# ML Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CLASSIFIER_MODEL=facebook/bart-large-mnli
SUMMARIZER_MODEL=facebook/bart-large-cnn
RAG_MODEL=HuggingFaceTB/SmolLM2-360M-Instruct
DUPLICATE_THRESHOLD=0.85

# Personalization weights (must sum to 1.0)
ALPHA_RECENCY=0.3
BETA_CATEGORY=0.35
GAMMA_EMBEDDING=0.35

# Scheduler
INGESTION_INTERVAL_MINUTES=30

# Logging
LOG_LEVEL=INFO
